# Claude Code 环境变量示例
# 用法：复制为 .env 并填入真实的 ANTHROPIC_AUTH_TOKEN
# 或在系统环境变量中设置以下变量

# 认证令牌（必填，需替换为实际值）
ANTHROPIC_AUTH_TOKEN=<YOUR_ANTHROPIC_AUTH_TOKEN>

# API 代理地址（Enflame）
ANTHROPIC_BASE_URL=https://api.enflame.cn

# 默认模型
ANTHROPIC_MODEL=kimi-k2.7-code-highspeed
ANTHROPIC_SMALL_FAST_MODEL=deepseek-v4-pro

# Claude Code 行为开关
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
CLAUDE_CODE_DISABLE_AUTH=1
CLAUDE_CODE_DISABLE_UPDATE=1
CLAUDE_CODE_DISABLE_ANALYTICS=1
CLAUDE_CODE_ATTRIBUTION_HEADER=0
CLAUDE_CODE_MAX_CONTEXT_TOKENS=262144
